{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Node/Bun server",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["bun-types", "node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true
  }
}
