{
  "name": "@itin/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate --schema=./prisma/schema",
    "migrate": "prisma migrate dev --schema=./prisma/schema",
    "migrate:deploy": "prisma migrate deploy --schema=./prisma/schema",
    "push": "prisma db push --schema=./prisma/schema",
    "studio": "prisma studio --schema=./prisma/schema",
    "seed": "bun run src/seed.ts",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@itin/config": "workspace:*",
    "prisma": "^6.1.0",
    "typescript": "^5.7.3"
  }
}
