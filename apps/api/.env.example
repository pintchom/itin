# apps/api — copy to apps/api/.env for local dev. Bun auto-loads it.
NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/itin

WEB_ORIGIN=http://localhost:5173
API_ORIGIN=http://localhost:3001
IMAGE_STORAGE_DIR=./.data/images

# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-32-bytes-of-random
AUTH_URL=http://localhost:3001

# Enables /api/auth/dev-login so we can sign in by name during early dev.
# Set to 0 in production.
DEV_AUTH_ENABLED=1

# Sign in with Google — leave empty to skip. Required for real OAuth.
# Get these from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (local): http://localhost:3001/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
